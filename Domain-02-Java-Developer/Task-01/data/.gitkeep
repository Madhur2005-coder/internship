// ─────────────────────────────────────────────────────────────
// 1. Hello World & Environment Test
//    Purpose : Validate JDK installation and IDE configuration.
// ─────────────────────────────────────────────────────────────
public class HelloWorld {
    public static void main(String[] args) {
        System.out.println("Hello World! JDK setup successful.");
    }
}


// ─────────────────────────────────────────────────────────────
// 2. Temperature Converter
//    Purpose : Convert Fahrenheit to Celsius.
//    Concepts: primitive types (double), arithmetic operators,
//              formatted output (printf).
// ─────────────────────────────────────────────────────────────
public class TemperatureConverter {
    public static void main(String[] args) {
        double fahrenheit = 98.6;
        double celsius = (fahrenheit - 32) * 5 / 9;
        System.out.printf("%.2f°F = %.2f°C%n", fahrenheit, celsius);
    }
}


// ─────────────────────────────────────────────────────────────
// 3. Even / Odd Checker
//    Purpose : Determine whether a number is even or odd.
//    Concepts: modulo operator (%), ternary operator.
// ─────────────────────────────────────────────────────────────
public class EvenOddChecker {
    public static void main(String[] args) {
        int number = 27;
        System.out.println(number + " is " + (number % 2 == 0 ? "Even" : "Odd"));
    }
}


// ─────────────────────────────────────────────────────────────
// 4. Multiplication Table
//    Purpose : Print a multiplication table using a for loop.
//    Concepts: for loop, formatted string output.
// ─────────────────────────────────────────────────────────────
public class MultiplicationTable {
    public static void main(String[] args) {
        int num = 5;
        System.out.println("Multiplication table for " + num + ":");
        for (int i = 1; i <= 10; i++) {
            System.out.printf("%d x %d = %d%n", num, i, num * i);
        }
    }
}


// ─────────────────────────────────────────────────────────────
// 5. Digit Counter
//    Purpose : Count how many digits are in an integer.
//    Concepts: while loop, integer division (/= 10), counter variable.
// ─────────────────────────────────────────────────────────────
public class DigitCounter {
    public static void main(String[] args) {
        int number = 12345;
        int count = 0;
        int temp = number;          // preserve original value for display
        while (temp != 0) {
            temp /= 10;
            count++;
        }
        System.out.println("Total digits in " + number + ": " + count);
    }
}


// ─────────────────────────────────────────────────────────────
// 6. Fibonacci Series
//    Purpose : Generate the first N Fibonacci numbers.
//    Concepts: multiple variable assignment, value swapping.
// ─────────────────────────────────────────────────────────────
public class FibonacciSeries {
    public static void main(String[] args) {
        int n = 10, t1 = 0, t2 = 1;
        System.out.print("Fibonacci Series (" + n + " terms): ");
        for (int i = 1; i <= n; i++) {
            System.out.print(t1 + (i < n ? ", " : "\n"));
            int sum = t1 + t2;
            t1 = t2;
            t2 = sum;
        }
    }
}


// ─────────────────────────────────────────────────────────────
// 7. Prime Number Checker
//    Purpose : Determine whether a given number is prime.
//    Concepts: boolean flag, Math.sqrt optimisation, break.
// ─────────────────────────────────────────────────────────────
public class PrimeChecker {
    public static void main(String[] args) {
        int num = 29;
        boolean isPrime = (num > 1);            // numbers <= 1 are not prime

        for (int i = 2; i <= Math.sqrt(num); i++) {
            if (num % i == 0) {
                isPrime = false;
                break;                          // no need to check further
            }
        }
        System.out.println(num + (isPrime ? " is a prime number." : " is not a prime number."));
    }
}


// ─────────────────────────────────────────────────────────────
// 8. Day Finder
//    Purpose : Map an integer (1–7) to a weekday name.
//    Concepts: switch expression with arrow syntax, default case.
// ─────────────────────────────────────────────────────────────
public class DayFinder {
    public static void main(String[] args) {
        int day = 3;
        switch (day) {
            case 1 -> System.out.println("Monday");
            case 2 -> System.out.println("Tuesday");
            case 3 -> System.out.println("Wednesday");
            case 4 -> System.out.println("Thursday");
            case 5 -> System.out.println("Friday");
            case 6 -> System.out.println("Saturday");
            case 7 -> System.out.println("Sunday");
            default -> System.out.println("Invalid day number. Enter 1–7.");
        }
    }
}


// ─────────────────────────────────────────────────────────────
// 9. Array Operations
//    Purpose : Compute sum, minimum, and maximum of an array.
//    Concepts: array initialisation, enhanced for loop.
// ─────────────────────────────────────────────────────────────
public class ArrayOperations {
    public static void main(String[] args) {
        int[] numbers = {5, 2, 9, 1, 5};
        int sum = 0, min = numbers[0], max = numbers[0];

        for (int n : numbers) {
            sum += n;
            if (n < min) min = n;
            if (n > max) max = n;
        }

        System.out.println("Array   : " + java.util.Arrays.toString(numbers));
        System.out.println("Sum     : " + sum);
        System.out.println("Minimum : " + min);
        System.out.println("Maximum : " + max);
    }
}


// ─────────────────────────────────────────────────────────────
// 10. Circle Operations
//     Purpose : Calculate circumference and area of a circle.
//     Concepts: static helper methods, Math.PI, method parameters.
// ─────────────────────────────────────────────────────────────
public class CircleOperations {
    public static void main(String[] args) {
        double radius = 7.5;
        System.out.printf("Radius         : %.2f%n", radius);
        System.out.printf("Circumference  : %.2f%n", calculateCircumference(radius));
        System.out.printf("Area           : %.2f%n", calculateArea(radius));
    }

    static double calculateCircumference(double r) {
        return 2 * Math.PI * r;
    }

    static double calculateArea(double r) {
        return Math.PI * r * r;
    }
}
